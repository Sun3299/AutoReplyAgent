# =============================================
# AutoReply .gitignore
# 敏感数据保护 - 请勿上传包含密钥的文件
# =============================================

# --------------- 敏感文件（最高优先级）---------------

# 真实环境变量（包含 API Key、Cookie 等敏感凭证）
.env
.env.local
.env.*.local

# 闲鱼渠道 Cookie（包含真实用户会话）
xianyu/.env
xianyu/.env.local
channels/xianyu/memory/*.jsonl
channels/xianyu/memory/*.jsonl

# --------------- IDE / 编辑器 ---------------

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------- Python 缓存 ---------------

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# --------------- 测试 / 缓存 ---------------

.pytest_cache/
.coverage
htmlcov/
.cache
*.log

# --------------- 数据文件（包含用户数据）---------------

# 向量数据库（包含业务知识库数据）
data/
test_rag_data/

# Session 会话数据（包含用户聊天记录）
# channels/*/memory/  # 如有需要可按渠道开启
channels/xianyu/memory/

# --------------- 本地 Embedding 模型（体积大，应从网盘分发）---------------

models/
!models/README.md  # 保留模型说明

# --------------- 其他 ---------------

# 临时文件
*.tmp
*.bak
*.backup

# 文档（按需保留）
# my_requirement.txt  # 注：这个文件是项目笔记，不是 pip requirements

# --------------- 保持 track 的文件 ---------------

# 以 .env.example 为模板创建 .env
!.env.example

# 保留目录结构（空目录）
# 如需 track 某空目录，在其中添加 .gitkeep
